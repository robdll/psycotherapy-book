# Local MongoDB: docker compose up -d (replica set rs0 on host port 27018 — required by Prisma)
DATABASE_URL="your-mongodb-connection-string"

# MongoDB Atlas: clusters are already replica sets. Atlas “Connect → Drivers” often gives `...mongodb.net/?appName=…`
# with NO database path — Prisma requires one. Insert your DB name before `?`, e.g. `/psicology_booking`:
# DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/psicology_booking?retryWrites=true&w=majority&appName=Cluster0"

# Local dev: http://localhost:3000 — Production: https://cintyaflores.com (or https://www... — pick one and use everywhere)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# After deploy, open GET {NEXT_PUBLIC_APP_URL}/api/health — expect {"ok":true,"database":"up"} if Mongo is reachable from Vercel.
# Admin 500 JSON now includes safe fields: `cause`, `prisma_code` (no secrets). Optional verbose `detail` with ADMIN_API_DEBUG=1.
# ADMIN_API_DEBUG="1"

# Admin UI (/admin) — set a strong password
ADMIN_PASSWORD="change-me-in-production"
# Used to sign admin session cookie (min 32 chars recommended)
SESSION_SECRET="generate-a-long-random-string-for-cookie-signing"

# Google OAuth: Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# (create a "Web application" client). Client ID and Client secret are on that client's detail page.
# Enable Google Calendar API; OAuth consent screen must be configured; redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Mercado Pago (Production or Test access token from dashboard)
MERCADOPAGO_ACCESS_TOKEN=""
# Optional: verify webhook signatures (Mercado Pago secret from webhook config)
MERCADOPAGO_WEBHOOK_SECRET=""

# --- Analytics (optional) ---
# PostHog: project API key (same key for client init and server capture). Leave unset to disable.
NEXT_PUBLIC_POSTHOG_KEY=""
# PostHog region host (default US). EU example: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Meta Pixel (browser) — public id, only loads after user accepts cookies in the banner.
NEXT_PUBLIC_META_PIXEL_ID=""

# Meta Conversions API — server-side Purchase on confirmed booking (same pixel id as above + access token from Events Manager).
META_PIXEL_ID=""
META_CAPI_ACCESS_TOKEN=""
