# Local MongoDB (docker compose up -d mongo) — mapped to host port 27018 so 27017 can stay free:
DATABASE_URL="mongodb://127.0.0.1:27018/psicology_booking"

# MongoDB Atlas (production): use the SRV string from Atlas → Connect → Drivers, e.g.
# DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/psicology_booking?retryWrites=true&w=majority"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin UI (/admin) — set a strong password
ADMIN_PASSWORD="change-me-in-production"
# Used to sign admin session cookie (min 32 chars recommended)
SESSION_SECRET="generate-a-long-random-string-for-cookie-signing"

# Google OAuth (Calendar API enabled; consent screen; redirect = {APP_URL}/api/auth/google/callback)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Mercado Pago (Production or Test access token from dashboard)
MERCADOPAGO_ACCESS_TOKEN=""
# Optional: verify webhook signatures (Mercado Pago secret from webhook config)
MERCADOPAGO_WEBHOOK_SECRET=""
